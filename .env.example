# ============================================================================
# Nexus SENTINEL - Environment Configuration
# ============================================================================

# Application
ENVIRONMENT=development
DEBUG=true
APP_NAME=Nexus SENTINEL
API_TITLE=Nexus SENTINEL API
API_VERSION=1.0.0

# ============================================================================
# Database
# ============================================================================
DB_USER=nexus_admin
DB_PASSWORD=sentinel_secure_2024
DB_NAME=nexus_sentinel
DB_PORT=5432
DATABASE_URL=postgresql://nexus_admin:sentinel_secure_2024@postgres:5432/nexus_sentinel
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE=3600

# ============================================================================
# Redis Cache
# ============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ============================================================================
# Security
# ============================================================================
SECRET_KEY=your-super-secret-key-change-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://frontend:5173"]

# ============================================================================
# API Configuration
# ============================================================================
API_PORT=8000

# ============================================================================
# Frontend Configuration
# ============================================================================
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ============================================================================
# Geospatial Configuration
# ============================================================================
SRID=4326

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Monitoring & Observability
# ============================================================================
# Enable metrics, tracing, etc.
ENABLE_METRICS=true
ENABLE_TRACING=false
